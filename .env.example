APP_ENV=local
APP_URL=http://localhost:8888
# En production, APP_ENV=production force la redirection HTTPS si la requete arrive en HTTP.
DB_HOST=127.0.0.1
DB_PORT=8889
DB_NAME=secure_recipes_greta92
DB_USER=root
DB_PASSWORD=root
LOG_RETENTION_DAYS=90

# MAMP par defaut : DB_PORT=8889, DB_USER=root, DB_PASSWORD=root.
# Serveur PHP + MySQL local classique : souvent DB_PORT=3306.
# MySQL temporaire de test : DB_PORT=3307, DB_USER=root, DB_PASSWORD vide.
