{
  "name": "greta92/mijote-maison",
  "description": "Projet final GRETA 92 - site securise de recettes de cuisine.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "ext-fileinfo": "*",
    "ext-iconv": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "php": ">=8.2",
    "altorouter/altorouter": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0"
  },
  "scripts": {
    "test": "phpunit"
  },
  "autoload": {
    "files": [
      "config/app.php",
      "config/database.php",
      "src/Utils/Helpers/functions.php",
      "src/Utils/Helpers/flash.php",
      "src/Utils/Helpers/layout.php",
      "src/Utils/Helpers/pedagogy.php",
      "src/Utils/Security/headers.php",
      "src/Utils/Security/auth.php",
      "src/Utils/Security/csrf.php",
      "src/Utils/Security/brute_force.php",
      "src/Utils/Security/upload.php",
      "src/Utils/Validation/admin_validation.php",
      "src/Utils/Validation/recipe_validation.php"
    ],
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "sort-packages": true
  }
}
